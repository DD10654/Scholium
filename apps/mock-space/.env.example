VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_publishable_key_here

# Server-only, for the /api/prune-papers cron that deletes question papers once
# they are older than PAPER_RETENTION_DAYS (src/lib/paperRetention.ts). Set both
# in the Vercel project; neither is needed to run the app locally.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
# Vercel Cron sends this as `Authorization: Bearer <CRON_SECRET>`. Without it the
# endpoint refuses every request.
CRON_SECRET=a_long_random_string
