VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_publishable_key_here
VITE_SUPABASE_PROJECT_ID=your_project_id_here

# Google Cloud Text-to-Speech — powers server.js POST /api/speak
# Enable the "Cloud Text-to-Speech API" in a GCP project and create a service
# account with the "Cloud Text-to-Speech API User" role. Provide ONE of:
#   Option A (local dev): absolute path to the downloaded key file
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json
#   Option B (hosted/serverless): the key JSON inline on a single line
# GOOGLE_APPLICATION_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}
